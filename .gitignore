# ═══════════════════════════════════════════════════════════════════════════════
# .gitignore — NetMon: Real-Time Network Monitoring System
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec

# ─── Virtual Environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── IDE & Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Testing & Coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Exports (generated at runtime) ──────────────────────────────────────────
exports/

# ─── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ─── Distribution / Packaging ─────────────────────────────────────────────────
*.tar.gz
*.whl
